// Jenkinsfile: builds the api-gateway service (Gradle)
pipeline {
  agent any
  options {
    timestamps()
    ansiColor('xterm')
    buildDiscarder(logRotator(numToKeepStr: '30'))
    timeout(time: 30, unit: 'MINUTES')
  }
  stages {
    stage('Checkout') { steps { checkout scm } }
    stage('Build api-gateway') {
      steps {
        script {
          if (!fileExists('api-gateway')) {
            echo 'api-gateway directory not found; skipping build.'
            return
          }
          dir('api-gateway') {
            def gradleCmd = fileExists('gradlew') ? './gradlew' : 'gradle'
            echo "Running: ${gradleCmd} clean build --no-daemon"
            sh "${gradleCmd} clean build --no-daemon"
            archiveArtifacts artifacts: 'build/libs/*.jar', fingerprint: true
            junit allowEmptyResults: true, testResults: 'build/test-results/test/*.xml'
          }
        }
      }
    }
  }
  post {
    always { echo 'api-gateway pipeline finished' }
    failure { echo 'api-gateway build failed' }
  }
}

