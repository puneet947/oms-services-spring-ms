// Jenkinsfile: builds the order-service service (Gradle)
pipeline {
  agent any
  options {
    timestamps()
    ansiColor('xterm')
    buildDiscarder(logRotator(numToKeepStr: '30'))
    timeout(time: 30, unit: 'MINUTES')
  }
  stages {
    stage('Checkout') { steps { checkout scm } }
    stage('Build order-service') {
      steps {
        script {
          if (!fileExists('order-service')) {
            echo 'order-service directory not found; skipping build.'
            return
          }
          dir('order-service') {
            def gradleCmd = fileExists('gradlew') ? './gradlew' : 'gradle'
            echo "Running: ${gradleCmd} clean build --no-daemon"
            sh "${gradleCmd} clean build --no-daemon"
            archiveArtifacts artifacts: 'build/libs/*.jar', fingerprint: true
            junit allowEmptyResults: true, testResults: 'build/test-results/test/*.xml'
          }
        }
      }
    }
  }
  post {
    always { echo 'order-service pipeline finished' }
    failure { echo 'order-service build failed' }
  }
}

